{
    "name": "revvo/desafio",
    "description": "Desafio Revvo - stack PHP 8.3 com MVC leve, Tailwind e Gulp",
    "type": "project",
    "require": {
        "php": "^8.3",
        "ext-pdo": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "friendsofphp/php-cs-fixer": "^3.58"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "format": "php-cs-fixer fix --diff"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
